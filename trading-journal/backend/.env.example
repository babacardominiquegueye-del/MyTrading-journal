# =============================================================
# ENVIRONMENT VARIABLES - Trading Journal Backend
# =============================================================
# 
# WHY .env FILES MATTER:
# Environment variables keep sensitive data OUT of your codebase.
# If you hardcode secrets like JWT_SECRET or DB passwords into
# your code and push to GitHub, ANYONE can see them.
#
# RULE: .env files are NEVER committed to version control.
#       Always add .env to your .gitignore file!
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR values
# 3. Never share your .env file
# =============================================================

# MongoDB Connection String
# Local: mongodb://localhost:27017/trading-journal
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/trading-journal
MONGO_URI=mongodb://localhost:27017/trading-journal

# JWT Secret Key
# WHY JWT_SECRET? This is the "password" used to SIGN tokens.
# Anyone with this secret can create valid tokens for ANY user.
# Use a long, random string (32+ characters) in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry (how long tokens are valid)
# Examples: "7d" = 7 days, "24h" = 24 hours, "1h" = 1 hour
JWT_EXPIRE=7d

# Server Port
# PORT 5000 is common for Express backends (React usually uses 3000)
PORT=5000

# Node Environment
# "development" enables detailed error messages
# "production" hides sensitive error details from users
NODE_ENV=development
