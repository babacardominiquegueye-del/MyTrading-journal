# ============================================================
# .env.example — Frontend (React)
# ============================================================
# Sur Vercel : ajoute cette variable dans
# Settings → Environment Variables
#
# En local : cp .env.example .env
#
# IMPORTANT : les variables React DOIVENT commencer par REACT_APP_
# Sinon React ne les verra pas !
# ============================================================

# URL de ton backend (Express sur Render)
# En local    : http://localhost:5000
# Sur Render  : https://ton-backend.onrender.com
REACT_APP_API_URL=http://localhost:5000/api
